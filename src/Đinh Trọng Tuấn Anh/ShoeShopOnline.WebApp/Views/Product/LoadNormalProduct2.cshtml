@model IEnumerable<ShoeShopOnline.Model.DAL.Product>

@if (Model != null)
{
    <style>
        /* CSS cho cái khung chứa (BẮT BUỘC PHẢI CÓ ĐỂ DÀN NGANG) */
        .product-grid-container {
            display: flex;
            flex-wrap: wrap;
            gap: 25px;
            justify-content: center;
            width: 100%;
        }

        /* CSS cho từng thẻ sản phẩm */
        .product-card {
            width: 260px;
            background: #ffffff;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            display: flex;
            flex-direction: column;
            border: 1px solid #f0f0f0;
            box-shadow: 0 4px 10px rgba(0,0,0,0.04);
            transition: all 0.3s ease;
            position: relative; 
        }

        .product-card:hover {
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
            transform: translateY(-6px);
            border-color: #e0e0e0;
        }

        .img-container {
            position: relative;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .product-img {
            width: 100%;
            height: 240px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .mask {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .img-container:hover .mask { opacity: 1; }
        .img-container:hover .product-img { transform: scale(1.05); }

        .mask span {
            color: #fff;
            border: 1px solid #fff;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
            text-decoration: none;
        }

        .product-title {
            font-size: 16px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 12px;
            line-height: 1.4;
            height: 44px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }
        
        .product-title a {
            color: inherit;
            text-decoration: none;
        }

        .product-pricing { margin-top: auto; margin-bottom: 15px; }

        .product-price-old {
            color: #a4b0be;
            text-decoration: line-through; 
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 4px;
            display: block;
        }

        .product-price-new {
            color: #ff4757;
            font-size: 20px;
            font-weight: 800;
        }

        .add-to-cart-btn {
            display: block;
            width: 100%;
            padding: 10px 0;
            background-color: #ff4757;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
            transition: background-color 0.2s;
            text-align: center;
        }

        .add-to-cart-btn:hover { background-color: #ff6b81; color: white;}

        .out-of-stock-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #2f3542;
            color: #fff;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            z-index: 10;
        }
        
        .card-disabled { opacity: 0.7; }
    </style>

    <div class="product-grid-container">
        @foreach (var item in Model)
        {
            var url = "/chi-tiet-san-pham/" + item.MetaTitle + "/" + item.Id;
            
            var isOutOfStock = item.Quantity <= 0;
            var hasPromo = item.PromotionPrice != null && item.PromotionPrice > 0;
            
            <div class="product-card @(isOutOfStock ? "card-disabled" : "")">
                
                <a href="@url" class="img-container">
                    <img src="@item.UrlImage" alt="@item.Name" class="product-img" />
                    
                    @if (isOutOfStock)
                    {
                        <span class="out-of-stock-badge">Hết hàng</span>
                    }
                    else
                    {
                        <div class="mask">
                            <span>Xem chi tiết</span>
                        </div>
                    }
                </a>

                <h4 class="product-title"><a href="@url">@item.Name</a></h4>

                <div class="product-pricing">
                    @if (hasPromo)
                    {
                        <span class="product-price-old">@item.Price.GetValueOrDefault(0).ToString("N0") đ</span>
                        <span class="product-price-new">@item.PromotionPrice.GetValueOrDefault(0).ToString("N0") đ</span>
                    }
                    else
                    {
                        <span class="product-price-new" style="margin-top: 25px; display: block;">
                            @(item.Price.HasValue ? item.Price.Value.ToString("N0") + " đ" : "Liên hệ")
                        </span>
                    }
                </div>

                @if (!isOutOfStock)
                {
                    <a class="add-to-cart-btn" href="/them-gio-hang?productId=@item.Id&quantity=1">
                        <i class="fa fa-shopping-cart"></i> Thêm giỏ hàng
                    </a>
                }
                else
                {
                    <button class="add-to-cart-btn" style="background-color: #ccc; cursor: not-allowed; border: none;" disabled>
                        Tạm hết hàng
                    </button>
                }
            </div>
        }
    </div>
}